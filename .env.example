
## Cloud model (paste your DeepInfra key here)
# OPENAI_API_KEY=
# OPENAI_COMPAT_BASE_URL=https://api.deepinfra.com/v1/openai
# OPENAI_REQUEST_TIMEOUT_MS=180000
# OPENAI_MAX_OUTPUT_TOKENS=4096
# OPENAI_CONTEXT_WINDOW_TOKENS=262144
# OPENAI_INPUT_BUDGET_TOKENS=8000
# NANOCLAW_DEFAULT_PROVIDER=openai_compatible
# NANOCLAW_DEFAULT_MODEL=Qwen/Qwen3-235B-A22B-Instruct-2507
# NANOCLAW_DEFAULT_BASE_URL=https://api.deepinfra.com/v1/openai
# NANOCLAW_INPUT_COST_PER_MTOKENS=0.071
# NANOCLAW_OUTPUT_COST_PER_MTOKENS=0.10
# NANOCLAW_CONTEXT_SOFT_CAP_CHARS=32000
# NANOCLAW_CONTEXT_HARD_CAP_CHARS=42000
# NANOCLAW_CONTEXT_RESERVED_TOOL_CHARS=8000
# NANOCLAW_POLL_INTERVAL_MS=800
# NANOCLAW_IPC_POLL_INTERVAL_MS=400
# NANOCLAW_AGENT_IPC_POLL_MS=200
# NANOCLAW_EXECUTION_BACKEND=native  # native|docker (default: auto by provider)
# NATIVE_AGENT_TIMEOUT_MS=300000      # leave room for slower local models

## Telegram
# TELEGRAM_BOT_TOKEN=

## Discord
# DISCORD_BOT_TOKEN=

## Web tooling
# WEB_SEARCH_PROVIDER=auto            # auto|searxng|duckduckgo|playwright|off
# SEARXNG_BASE_URL=http://127.0.0.1:8888
# WEB_FETCH_PROVIDER=auto             # auto|http|playwright
# WEB_TOOL_ENABLE_MODE=auto           # auto|always (auto enables tools only on likely web intent)
# WEB_BROWSER_FALLBACK=playwright     # playwright|none
# WEB_TOOL_MAX_STEPS=8
# WEB_TOOL_MAX_SEARCH_CALLS=4
# WEB_SEARCH_MAX_RESULTS=5
# WEB_TOOL_SEARCH_TIMEOUT_MS=10000
# WEB_TOOL_PAGE_FETCH_TIMEOUT_MS=12000
# WEB_FETCH_MAX_CHARS=12000
# WEB_FETCH_MAX_RESPONSE_BYTES=2000000
# WEB_SEARCH_CACHE_TTL_MINUTES=15
# WEB_FETCH_CACHE_TTL_MINUTES=15
# WEB_TOOL_TOTAL_BUDGET_MS=45000
# WEB_TOOL_LOOP_BUDGET_MS=90000
# WEB_RESTRICTED_DOMAINS=linkedin.com,www.linkedin.com,m.linkedin.com
# WEB_TOOL_MODEL_TOOL_CALLS=0

## Heartbeat (proactive agent loop)
# HEARTBEAT_INTERVAL=1800000
# HEARTBEAT_TIMEOUT=180000
# HEARTBEAT_MIN_GAP=600000

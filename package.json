{
  "name": "microclaw",
  "version": "1.2.1",
  "description": "Personal Claude assistant. Lightweight, secure, customizable.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "microclaw": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:fix": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "prepare": "husky",
    "setup": "tsx setup/index.ts",
    "command-center": "tsx src/cli/index.ts",
    "auth": "tsx src/whatsapp-auth.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "probe:web": "tsx scripts/probe-web.ts",
    "probe:browser": "tsx scripts/probe-browser-tool-calling.ts",
    "probe:browser-runtime": "tsx scripts/probe-browser-runtime.ts",
    "debug": "tsx src/cli/index.ts debug",
    "gate": "npm run typecheck && npm run test && npm run build && npm --prefix container/agent-runner run build && npm run command-center -- launch-check --deep"
  },
  "dependencies": {
    "better-sqlite3": "^11.10.0",
    "cron-parser": "^5.5.0",
    "discord.js": "^14.25.1",
    "neo-blessed": "^0.2.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "playwright": "^1.58.2",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/blessed": "^0.1.27",
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^4.0.18",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=20"
  }
}

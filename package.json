{
  "name": "microclaw",
  "version": "1.2.1",
  "description": "Personal Claude assistant. Lightweight, secure, customizable.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "microclaw": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "build:ui": "cd ui && npm run build",
    "build:all": "npm run build:ui && npm run build",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:fix": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "prepare": "husky",
    "setup": "tsx setup/index.ts",
    "command-center": "tsx src/cli/index.ts",
    "auth": "tsx src/whatsapp-auth.ts",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "probe:web": "tsx scripts/probe-web.ts",
    "probe:browser": "tsx scripts/probe-browser-tool-calling.ts",
    "probe:browser-runtime": "tsx scripts/probe-browser-runtime.ts",
    "cleanup:memory": "tsx scripts/cleanup-memory.ts",
    "debug": "tsx src/cli/index.ts debug",
    "gate": "npm run typecheck && npm run test && npm run build && npm --prefix container/agent-runner run build && npm run command-center -- launch-check --deep"
  },
  "dependencies": {
    "@onecli-sh/sdk": "^0.2.0",
    "better-sqlite3": "^11.10.0",
    "cron-parser": "^5.5.0",
    "detect-port": "^2.1.0",
    "discord.js": "^14.25.1",
    "express": "^5.2.1",
    "grammy": "^1.39.3",
    "neo-blessed": "^0.2.0",
    "open": "^11.0.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "playwright": "^1.58.2",
    "ws": "^8.20.0",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.35.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/blessed": "^0.1.27",
    "@types/express": "^5.0.6",
    "@types/node": "^22.10.0",
    "@types/supertest": "^7.2.0",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9.35.0",
    "eslint-plugin-no-catch-all": "^1.1.0",
    "globals": "^15.12.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "supertest": "^7.2.2",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.35.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=20"
  }
}
